# =============================================================================
# .env.production — Copy this to .env.production on the server
# Generate secrets with:  openssl rand -hex 32
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
APP_NAME=PFF Lab
API_PREFIX=/api/v1
CORS_ORIGINS=["https://lab.example.com"]

# ── Domain (used by Caddyfile) ───────────────────────────────────────────────
DOMAIN=lab.example.com

# ── Database (managed by docker-compose.prod.yml) ────────────────────────────
# DATABASE_URL is auto-composed by docker-compose.prod.yml from these:
POSTGRES_USER=pff
POSTGRES_PASSWORD=CHANGE-ME-STRONG-PASSWORD
POSTGRES_DB=pff_lab

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=replace-with-a-random-string-at-least-32-characters-long
AUTH_ACCESS_TOKEN_TTL_MINUTES=480
AUTH_INITIAL_OPERATOR_EMAIL=admin@lab.example.com
AUTH_INITIAL_OPERATOR_PASSWORD=CHANGE-ME
AUTH_INITIAL_OPERATOR_FULL_NAME=Admin
AUTH_INITIAL_OPERATOR_ROLE=admin

# ── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_SIMULATION_MODE=false
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-me
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── AI / LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_API_KEY=
GEMINI_MODEL=google/gemini-3-flash-preview
CHATBOT_ENABLED=true
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Lab hours ────────────────────────────────────────────────────────────────
LAB_OPENING_HOUR=8
LAB_CLOSING_HOUR=18
LAB_TIMEZONE=Africa/Casablanca

# ── Container images (updated by deploy script) ─────────────────────────────
BACKEND_IMAGE=ghcr.io/owner/repository/backend:latest
FRONTEND_IMAGE=ghcr.io/owner/repository/frontend:latest

# ── Backend tuning ───────────────────────────────────────────────────────────
UVICORN_WORKERS=2
SEED_DEMO_DATA=false
