# ─── Authentication ───────────────────────────────────────────────
AUTH_SECRET_KEY=change-this-to-a-random-string-at-least-32-chars
AUTH_INITIAL_OPERATOR_EMAIL=admin@lab.local
AUTH_INITIAL_OPERATOR_PASSWORD=admin123
AUTH_INITIAL_OPERATOR_FULL_NAME=Administrateur
AUTH_INITIAL_OPERATOR_ROLE=admin

# ─── Database (overridden by docker-compose for the backend) ─────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_app

# ─── WhatsApp Business API ───────────────────────────────────────
WHATSAPP_SIMULATION_MODE=true
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Chatbot / RAG ──────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CHATBOT_ENABLED=true

# ─── App ─────────────────────────────────────────────────────────
ENVIRONMENT=local
CORS_ORIGINS=["http://localhost:3000"]
