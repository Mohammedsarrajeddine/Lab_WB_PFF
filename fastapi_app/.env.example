APP_NAME=FastAPI App
ENVIRONMENT=local
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
WHATSAPP_SIMULATION_MODE=true
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me
AUTH_SECRET_KEY=change-this-auth-secret
AUTH_ACCESS_TOKEN_TTL_MINUTES=480
AUTH_INITIAL_OPERATOR_EMAIL=
AUTH_INITIAL_OPERATOR_PASSWORD=
AUTH_INITIAL_OPERATOR_FULL_NAME=Intake Operator
AUTH_INITIAL_OPERATOR_ROLE=admin
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_app
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# --- Chatbot / Module 2 ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CHATBOT_ENABLED=true
LAB_OPENING_HOUR=8
LAB_CLOSING_HOUR=18
LAB_TIMEZONE=Africa/Casablanca
EMBEDDING_MODEL=all-MiniLM-L6-v2
